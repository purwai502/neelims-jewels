# =====================
# Python / Backend
# =====================

# Virtual environment
venv/
env/
.venv/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# PyInstaller
*.spec

# Unit test / coverage
.coverage
htmlcov/
.pytest_cache/

# Environment variables (sensitive credentials!)
backend/.env
.env
.env.*

# Uploaded files (user-generated content, not source code)
backend/uploads/

# =====================
# Next.js / Frontend
# =====================

# Dependencies (already handled by frontend/.gitignore but also root-level)
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/

# =====================
# macOS
# =====================
.DS_Store
.AppleDouble
.LSOverride

# =====================
# IDE / Editors
# =====================
.vscode/
.idea/
*.swp
*.swo
*~

# =====================
# Logs
# =====================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
